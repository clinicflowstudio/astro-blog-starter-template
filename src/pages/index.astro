---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Clinic Flow Studio</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: Inter, sans-serif;
      background: #f6f1e7;
      color: #2f3a2f;
    }

    h1, h2 {
      font-family: "Playfair Display", serif;
    }

    .hero {
      text-align: center;
      padding: 120px 20px;
      background: linear-gradient(135deg, #dfe8d5, #f6f1e7);
    }

    .hero h1 {
      font-size: 60px;
      margin-bottom: 20px;
    }

    .hero p {
      max-width: 700px;
      margin: auto;
      font-size: 20px;
      line-height: 1.7;
    }

    .button {
      display: inline-block;
      margin-top: 30px;
      padding: 14px 28px;
      background: #4f6b4f;
      color: white;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
    }

    .section {
      max-width: 1000px;
      margin: auto;
      padding: 80px 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .card {
      background: white;
      padding: 30px;
      border-radius: 14px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    footer {
      text-align: center;
      padding: 40px;
      opacity: 0.7;
    }
  </style>
</head>

<body>

  <Header />

  <section class="hero">
    <h1>Clinic Flow Studio</h1>

    <p>
      Thoughtfully designed veterinary templates to simplify clinic life,
      reduce overwhelm, and help veterinary professionals stay organized.
    </p>

    <a class="button" href="https://www.etsy.com/shop/ClinicFlowStudioCo">
      Visit My Etsy Shop
    </a>
  </section>

  <section class="section">

    <h2 style="text-align:center;">What You'll Find</h2>

    <div class="grid">

      <div class="card">
        📝 Printable Veterinary Forms
      </div>

      <div class="card">
        📊 Workflow & Organization Tools
      </div>

      <div class="card">
        📅 Clinic Tracking Systems
      </div>

    </div>

  </section>

  <section class="section" style="text-align:center;">

    <h2>Created for Real Clinic Life</h2>

    <p style="max-width:700px; margin:auto;">
      Every template is designed with simplicity, efficiency,
      and real veterinary workflows in mind —
      helping busy clinics feel a little calmer and more organized.
    </p>

  </section>
<section class="section" style="text-align:center;">

  <h2>Meet My Pets 🐾</h2>

  <p style="max-width:700px; margin:auto;">
    A big part of my inspiration comes from the animals I share my life with.
    They remind me daily why veterinary care, compassion, and organization matter so much.
  </p>

  <div style="
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap:20px;
    margin-top:40px;
  ">

    <div style="background:white; padding:20px; border-radius:14px;">
      <h3>Juno</h3>
      <p>Sweet & curious companion</p>
    </div>

    <div style="background:white; padding:20px; border-radius:14px;">
      <h3>Luna</h3>
      <p>Calm, gentle, and observant</p>
    </div>

    <div style="background:white; padding:20px; border-radius:14px;">
      <h3>Sushi</h3>
      <p>Playful and full of personality</p>
    </div>

    <div style="background:white; padding:20px; border-radius:14px;">
      <h3>Sriracha</h3>
      <p>Spicy name, soft heart 🌶️</p>
    </div>

  </div>

</section>

  <Footer />

</body>
</html>
