---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
  <section style="padding:100px 20px; text-align:center; background:linear-gradient(135deg,#dfe8d5,#f6f1e7);">
    <h1 style="font-size:48px;">Clinic Flow Studio</h1>

    <p style="font-size:18px; max-width:700px; margin:20px auto;">
      Veterinary templates designed to bring calm, clarity, and organization to busy clinic life.
    </p>

    <a href="https://www.etsy.com/shop/ClinicFlowStudioCo"
       style="display:inline-block; padding:12px 24px; background:#4f6b4f; color:white; text-decoration:none; border-radius:8px;">
      Visit My Etsy Shop
    </a>
  </section>

  <section style="padding:60px 20px; text-align:center;">
    <h2>What I Create</h2>

    <p>Printable forms • Workflow tools • Vet tech templates • Organization systems</p>
  </section>

  <section style="padding:60px 20px; text-align:center;">
    <h2>Made for real clinic life</h2>
    <p>Simple, clean tools that reduce overwhelm in veterinary medicine.</p>
  </section>
</main>
		<Footer />
	</body>
</html>
