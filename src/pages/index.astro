---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Clinic Flow Studio</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: Inter, sans-serif;
      background: #f6f1e7;
      color: #2f3a2f;
    }

    h1, h2 {
      font-family: "Playfair Display", serif;
    }

    .hero {
      text-align: center;
      padding: 120px 20px;
      background: linear-gradient(135deg, #dfe8d5, #f6f1e7);
    }

    .hero h1 {
      font-size: 60px;
      margin-bottom: 20px;
    }

    .hero p {
      max-width: 700px;
      margin: auto;
      font-size: 20px;
      line-height: 1.7;
    }

    .button {
      display: inline-block;
      margin-top: 30px;
      padding: 14px 28px;
      background: #4f6b4f;
      color: white;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
    }

    .section {
      max-width: 1000px;
      margin: auto;
      padding: 80px 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .card {
      background: white;
      padding: 30px;
      border-radius: 14px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    footer {
      text-align: center;
      padding: 40px;
      opacity: 0.7;
    }

/* 📱 MOBILE FIX */
@media (max-width: 768px) {

  body {
    font-size: 16px;
  }

  h1 {
    font-size: 32px !important;
    line-height: 1.2;
  }

  h2 {
    font-size: 24px !important;
  }

  p {
    font-size: 16px !important;
    line-height: 1.6;
  }

  .container {
    padding: 30px 16px !important;
  }

  .section {
    padding: 40px 16px !important;
  }

  /* Stack grids into single column */
  div[style*="grid-template-columns"] {
    grid-template-columns: 1fr !important;
  }

  /* Make cards breathe */
  .card {
    padding: 18px !important;
  }

}
  </style>
</head>

<body>

  <Header />

  <section class="hero">
    <h1>Clinic Flow Studio</h1>

    <p>
      Thoughtfully designed veterinary templates to simplify clinic life,
      reduce overwhelm, and help veterinary professionals stay organized.
    </p>

    <a class="button" href="https://www.etsy.com/shop/ClinicFlowStudioCo">
      Visit My Etsy Shop
    </a>
  </section>

  <section class="section">

    <h2 style="text-align:center;">What You'll Find</h2>

    <div class="grid">

      <div class="card">
        📝 Printable Veterinary Forms
      </div>

      <div class="card">
        📊 Workflow & Organization Tools
      </div>

      <div class="card">
        📅 Clinic Tracking Systems
      </div>

    </div>

  </section>

  <section class="section" style="text-align:center;">

    <h2>Created for Real Clinic Life</h2>

    <p style="max-width:700px; margin:auto;">
      Every template is designed with simplicity, efficiency,
      and real veterinary workflows in mind —
      helping busy clinics feel a little calmer and more organized.
    </p>

  </section>

<!-- PETS SECTION -->
<section class="section" style="text-align:center;">

  <h2>Meet My Pets 🐾</h2>

  <p style="max-width:700px; margin:auto;">
    Behind every veterinary template is a team of highly unqualified assistants
    providing emotional support, chaos management, and occasional supervision.
  </p>

  <div class="grid">

    <!-- JUNO -->
    <div class="card">
      <h3>Juno</h3>

      <p>
        Juno serves as Head of Neighborhood Security,
        Chief Snack Quality Inspector,
        and part-time cardio coach.
      </p>

      <p>
        Equal parts athlete and cuddle consultant,
        Juno specializes in enthusiastic greetings,
        dramatic zoomies,
        and tactical squirrel surveillance through the living room window.
      </p>

      <p>
        Known for an unmatched work ethic and the ability
        to locate the loudest squeaky toy within seconds,
        Juno keeps morale high and personal space nonexistent.
      </p>
    </div>

    <!-- LUNA -->
    <div class="card">
      <h3>Luna</h3>

      <p>
        Luna is a certified people-person with years of experience
        in emotional support services and blanket theft operations.
      </p>

      <p>
        She excels in sunbeam supervision,
        treat negotiations,
        and making every guest feel personally chosen by royalty.
      </p>

      <p>
        With a calm but playful leadership style,
        Luna balances professionalism with a deep commitment
        to stealing hearts, spots on the couch,
        and occasionally unattended snacks.
      </p>
    </div>

    <!-- SUSHI -->
    <div class="card">
      <h3>Sushi</h3>

      <p>
        Sushi is an independent creative director
        specializing in advanced lounging techniques
        and midnight hallway marathons.
      </p>

      <p>
        Highly detail-oriented,
        Sushi maintains strict standards
        for nap quality,
        cardboard box inspections,
        and dramatic eye contact from across the room.
      </p>

      <p>
        While sometimes unavailable for meetings due to “personal reasons,”
        Sushi consistently delivers excellence in attitude,
        mystery,
        and tiny acts of emotional terrorism at 3 a.m.
      </p>
    </div>

    <!-- SRIRACHA -->
    <div class="card">
      <h3>Sriracha</h3>

      <p>
        Sriracha is a fast-paced operations specialist
        best known for elite curiosity
        and an extremely spicy personality.
      </p>

      <p>
        Whether conducting surprise countertop inspections
        or parkouring through the house at 2 a.m.,
        Sriracha approaches every challenge
        with passion, speed, and absolutely no fear.
      </p>

      <p>
        A natural entertainer with advanced communication skills
        (especially around mealtime),
        Sriracha keeps the household lively,
        unpredictable,
        and just slightly one missing object away from total chaos.
      </p>
    </div>

  </div>

</section>
  <Footer />

</body>
</html>
